# Godot
.godot/
android/

# SCons / build intermediates
.sconsign.dblite
.sconf_temp/
*.pyc
__pycache__/
*.os
*.o
*.obj
*.d
*.a
# GDExtension doc-data generator (regenerated from doc_classes/*.xml each build)
*.gen.cpp

# Compiled extension binaries (regenerated by tools/build.sh)
game/addons/*/bin/

# Claude Code: track the federation architecture (agents, slash commands,
# hooks, per-extension inboxes, structural settings). Per-user overrides
# (settings.local.json) and any local scratch stay ignored.
.claude/*
!.claude/agents/
!.claude/commands/
!.claude/hooks/
!.claude/inbox/
!.claude/settings.json

# Large test-scene assets (preserved locally; not tracked — may move to LFS later)
tools/test_scenes/marionette_kasumi/
game/assets/
game/tests/marionette/kasumi/

# Local-only scenes (per-machine scratch; suffix `_local`)
game/scenes/*_local.tscn

# Blender working directory (.blend files, exports, scratch — local-only)
blender/

# Godot engine docs (cloned reference, see docs/godot-docs.md)
docs/godot-docs/

# Image and 3D-asset binaries — local-only by default. Use `git add -f`
# (or a negation pattern) to track a specific file when needed.
*.png
*.glb
*.gltf

# Godot import metadata follows the binary it describes. Already-tracked
# .import files stay tracked (gitignore doesn't retroactively untrack); new
# .import files for ignored binaries are also ignored to avoid dangling
# references on fresh checkouts.
*.png.import
*.glb.import
*.gltf.import
