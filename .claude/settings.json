{
  "permissions": {
    "allow": [
      "Bash(./tools/build.sh tentacletech)",
      "Bash(./tools/build.sh marionette)",
      "Bash(./tools/build.sh tenticles)",
      "Bash(./tools/build.sh body_field)",
      "Bash(./tools/build_all.sh)",
      "Bash(git -C * log:*)",
      "Bash(git -C * status)",
      "Bash(git -C * status:*)",
      "Bash(git -C * diff:*)",
      "Bash(git -C * show:*)",
      "Bash(git -C * branch:*)",
      "Bash(git -C * rev-parse:*)",
      "Bash(git -C * ls-files:*)",
      "Bash(git -C * blame:*)",
      "Bash(bash $CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh)",
      "Edit(.claude/inbox/*)",
      "Write(.claude/inbox/*)",
      "Read(.claude/inbox/*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh\"" }
        ]
      }
    ]
  }
}
