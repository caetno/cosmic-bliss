#!/usr/bin/env python
import os

env = SConscript("../../godot-cpp/SConstruct")

env.Append(CPPPATH=["src/", "../shared/include/"])
sources = [Glob("src/*.cpp"), Glob("src/spline/*.cpp"), Glob("src/solver/*.cpp"), Glob("src/procedural/*.cpp"), Glob("src/collision/*.cpp")]

# Embed inspector / class documentation for editor + debug builds.
# The XML stubs in doc_classes/ were generated by:
#   godot --doctool extensions/tentacletech --gdextension-docs
# Filled-in descriptions become inspector tooltips on @exports and
# class help in the script editor's Ctrl+click flow. Release builds skip
# the doc payload — the stubs are a build-time-only artifact.
if env["target"] in ["editor", "template_debug"]:
    doc_data = env.GodotCPPDocData("src/gen/doc_data.gen.cpp", source=Glob("doc_classes/*.xml"))
    sources.append(doc_data)

addon_bin = "../../game/addons/tentacletech/bin"
if not os.path.isdir(addon_bin):
    os.makedirs(addon_bin, exist_ok=True)

if env["platform"] == "macos":
    library = env.SharedLibrary(
        "{}/libtentacletech.{}.{}.framework/libtentacletech.{}.{}".format(
            addon_bin, env["platform"], env["target"], env["platform"], env["target"]
        ),
        source=sources,
    )
else:
    library = env.SharedLibrary(
        "{}/libtentacletech{}{}".format(addon_bin, env["suffix"], env["SHLIBSUFFIX"]),
        source=sources,
    )

Default(library)
